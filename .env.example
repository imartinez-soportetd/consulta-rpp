# =============================================================================
# ConsultaRPP — CONFIGURACIÓN DEL CHATBOT LEGAL
# Sistema Inteligente de Consultas para Registro Público de la Propiedad
# =============================================================================
# Idioma: ESPAÑOL MÉXICO
# =============================================================================

# [1] SELECTOR DE PROVEEDOR LLM
# ─────────────────────────────────────────────────────────────────────────────
# Elige el proveedor de modelo de lenguaje a usar
# Opciones: groq | gemini | openai | anthropic | alibaba | openrouter
LLM_PROVIDER=groq

# [2] PROVEEDORES LLM EN LA NUBE (GRATUITOS/PAGADOS)
# ─────────────────────────────────────────────────────────────────────────────

# --- Groq (Llama 3.3 70B / Mixtral) — GRATIS (Beta) ---
GROQ_API_KEY=gsk_...                    # Get from https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (Flash 3.1) — Crédito gratis inicial ---
GOOGLE_API_KEY=AIza...        # Get from Google AI Studio
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- OpenRouter (Acceso a múltiples modelos) — Crédito gratis ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Anthropic Claude (Requiere crédito) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# --- Alibaba DashScope (Qwen) ---
ALIBABA_API_KEY=sk-...
ALIBABA_MODEL=qwen-plus

# [3] CONFIGURACIÓN OCR
# ─────────────────────────────────────────────────────────────────────────────
OCR_ENGINE=docling              # docling (local) | google_doc_ai
DOCLING_CHUNK_SIZE=auto         # auto = detectar según hardware
OMP_NUM_THREADS=0               # 0 = usar todos disponibles
MKL_NUM_THREADS=0

# [4] ALMACENAMIENTO - SeaweedFS
# ─────────────────────────────────────────────────────────────────────────────
SEAWEEDFS_MASTER_URL=http://seaweedfs-master:9333
SEAWEEDFS_VOLUME_URL=http://seaweedfs-volume:8080
SEAWEEDFS_REPLICATION=001       # 001 = 1 copia
SEAWEEDFS_BUCKET=propquery-docs

# [5] BASE DE DATOS - PostgreSQL + pgvector
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=3001
DB_USER=propquery_user
DB_PASSWORD=PropQuery_Secure_Pass_2026!
DB_NAME=propquery
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Vector embeddings configuration
EMBEDDING_DIMENSION=1536        # OpenAI embedding dimension
VECTOR_SIMILARITY_THRESHOLD=0.7 # Para RAG search

# [6] CACHE Y SESIONES - Valkey (Redis)
# ─────────────────────────────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0
VALKEY_PASSWORD=valkey_secure_pass_2026
CACHE_TTL=3600                  # Cache por 1 hora
SESSION_TTL=86400               # Sesión por 24 horas

# [7] PROCESAMIENTO ASÍNCRONO - Celery
# ─────────────────────────────────────────────────────────────────────────────
CELERY_BROKER=redis://valkey:6379/1
CELERY_BACKEND=redis://valkey:6379/2
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=info

# [8] CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=ConsultaRPP
APP_VERSION=0.1.0
APP_ENV=development             # development | staging | producción
DEBUG=true                      # cambiar a false en producción

# Frontend (Interfaz de Usuario)
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# Backend (Servidor de API)
BACKEND_URL=http://localhost:8000
BACKEND_PORT=8000
API_PREFIX=/api/v1

# Registros del Sistema
LOG_LEVEL=INFO                  # DEBUG | INFO | ADVERTENCIA | ERROR
LOG_FILE=logs/propquery.log

# [9] SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-12345
JWT_SECRET=your-jwt-secret-key-change-in-production

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# [10] LÍMITES Y CONFIGURACIÓN
# ─────────────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=104857600       # 100 MB en bytes
MAX_CONCURRENT_UPLOADS=5
DOCUMENT_BATCH_SIZE=10

# Chat configuration
MAX_CONTEXT_MESSAGES=20
MAX_RESPONSE_TOKENS=1024
TEMPERATURE=0.7                 # Creatividad del LLM (0-1)
TOP_P=0.9                       # Nucleus sampling

# Rate limiting
RATE_LIMIT_REQUESTS=100         # Requests por ventana
RATE_LIMIT_WINDOW=60            # Seconds

# [11] NOTIFICACIONES Y ALERTAS
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# [12] DESARROLLO
# ─────────────────────────────────────────────────────────────────────────────
# Usar esta sección solo para desarrollo local

# Hot reload del frontend
REACT_FAST_REFRESH=true

# Debug mode
SQLALCHEMY_ECHO=false           # Loguear queries SQL
HTTPX_TIMEOUT=30.0

# [13] DOCSTRING - Mapeo de Variables
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES DE USO:
#
# 1. Copiar este archivo: cp .env.example .env
#
# 2. Editar .env con valores reales:
#    - API Keys (Groq, Gemini, OpenAI, etc)
#    - Credenciales DB (cambiar contraseñas)
#    - URLs según tu ambiente
#
# 3. NO commitear .env a Git (ya está en .gitignore)
#
# 4. Para desarrollo local:
#    - Cambiar APP_ENV=development
#    - DEBUG=true
#    - FRONTEND_URL=http://localhost:3000
#
# 5. En producción:
#    - APP_ENV=production
#    - DEBUG=false
#    - SECRET_KEY y JWT_SECRET con valores seguros
#    - Usar https:// en URLs
#    - Cambiar todas las contraseñas
